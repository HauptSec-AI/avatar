# Copy this file to .env in the project root, then fill in your own values.
# See README.md "Setup instructions" for exactly how/where to get each one.
# .env is gitignored -- never commit your real values.

# ---- Core (required) ----
OPENROUTER_API_KEY=sk-or-v1-...
MODEL=openai/gpt-5.4-nano
OWNER_NAME=Your Name
ADMIN_PASSWORD=your-chosen-admin-password
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=sb_secret_...

# ---- Core (optional) ----
PUSHOVER_USER=
PUSHOVER_TOKEN=
SESSION_SECRET=a-long-random-string
COOKIE_SECURE=0

# ---- Voice (optional -- see SPEC-VOICE.md; leave blank to skip voice entirely) ----
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=
ELEVENLABS_WEBHOOK_SECRET=
# Separate secret for the two tool webhooks' bearer auth (faq_tool/push_tool) -- a
# different value from ELEVENLABS_WEBHOOK_SECRET above, so a leak of one doesn't
# compromise the other. Falls back to ELEVENLABS_WEBHOOK_SECRET (with a startup
# warning) if left blank while voice is otherwise configured.
ELEVENLABS_TOOL_SECRET=
VOICE_MAX_SESSION_SECONDS=600
ELEVENLABS_LLM=gpt-4o-mini
